# Copy to .env and fill in your values
# .env is gitignored — never commit the real file

# Bearer token for REST API authentication
ALFRED_API_KEY=your-secret-key-here

# Comma-separated list of allowed client IPs (in addition to localhost)
# Example: ALFRED_ALLOWED_IPS=192.168.1.100,192.168.1.101
ALFRED_ALLOWED_IPS=

# Ollama model to use (default: qwen3-coder:30b)
# Can also be set via --model CLI flag
# Examples: qwen3-coder:30b, qwen2.5:14b, qwen2.5:3b, qwen2.5:0.5b
ALFRED_MODEL=qwen3-coder:30b
